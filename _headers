/js/*.js
  Cache-Control: no-cache, must-revalidate

/css/*.css
  Cache-Control: no-cache, must-revalidate

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; connect-src 'self' https://tia-backend-production.up.railway.app; img-src 'self' data: blob:; media-src 'self' blob:; frame-ancestors 'none'